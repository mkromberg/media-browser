    ‚ąá r‚ÜźTest_CodeLocationResolvesRelativeToRealConfigFile;cls;j;rc;msg
    ‚ćĚ Now that Initialize exists, Jarvis runs it and starts serving instead
    ‚ćĚ of stopping at the missing-AppInitFn check. DYALOG_JARVIS_THREAD is
    ‚ćĚ forced to 'DEBUG' so Start returns immediately rather than blocking
    ‚ćĚ this test process forever inside the request-serving loop (Jarvis's
    ‚ćĚ default in a non-interactive session); Stop releases the port
    ‚ćĚ afterwards so later tests can bind it again.
      cls‚Üź‚éēFIX'file://',#.AplServiceRoot,'vendor/jarvis/Jarvis.dyalog'
      j‚Üź‚éēNEW cls(#.AplServiceRoot,'config/jarvis.config.json')
      j.DYALOG_JARVIS_THREAD‚Üź'DEBUG'
      (rc msg)‚Üźj.Start
      r‚Üź(rc‚Č°0)‚ąßj.CodeLocation.AppState.RootFolder‚Č°'/srv/photos'
      {}j.Stop
    ‚ąá

