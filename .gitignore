*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# Go
*.exe
*.test
*.out

# Rust
target/

# Environment files (covered by the protect-paths hook too, but belt and braces)
.env
.env.local
.env.*.local
